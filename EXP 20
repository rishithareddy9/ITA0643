import pandas as pd
from sklearn.linear_model import LinearRegression

data = {
"month":[1,2,3,4,5],
"sales":[200,250,300,350,400]
}

df = pd.DataFrame(data)

X = df[["month"]]
y = df["sales"]

model = LinearRegression()
model.fit(X,y)

pred = model.predict([[6]])

print("Predicted Sales for Month 6:",pred)
