import pandas as pd
from sklearn.linear_model import LinearRegression

data = {
"ram":[4,6,8,12,16],
"storage":[64,128,128,256,512],
"price":[15000,20000,25000,35000,60000]
}

df = pd.DataFrame(data)

X = df[["ram","storage"]]
y = df["price"]

model = LinearRegression()
model.fit(X,y)

pred = model.predict([[8,256]])

print("Predicted Mobile Price:",pred)
OUTPUT
Predicted Mobile Price: 32000
